// main.cpp
#include <GLFW/glfw3.h>
#include "Engine.h"

DXRender d3d11renderer;
Window GLFWHandler;

class Entrypoint {
public:
    static bool InitGLFW();
    static bool InitD3d11();
};


// Editor stuff
using namespace deform;

int main(HINSTANCE hInstance, HINSTANCE, LPSTR, int nCmdShow)
{
    if (!Entrypoint::InitGLFW()) { Logger::Log("InitGLFW FAILED\n");  return -1; }
    if (!Entrypoint::InitD3d11()) { Logger::Log("InitD3d11 FAILED\n"); return -1; }

	Logger::Log("Initialization complete. Entering main loop.");



    while (!glfwWindowShouldClose(GLFWHandler.GetWindow()))
    {
        glfwPollEvents();
    }


	Logger::Log("Exiting main loop. Cleaning up and shutting down.");
	Sleep(100); // Give some time for the log to flush before cleanup
    return 0;
}

void framebuffer_size_callback(GLFWwindow* window, int width, int height)
{
    d3d11renderer.Resize((UINT)width, (UINT)height);
}

bool Entrypoint::InitGLFW()
{
    if (!glfwInit())
        return false;

	Logger::Log("GLFW initialization successful.");
    return true;
}

bool Entrypoint::InitD3d11()
{
    if (!d3d11renderer.Initialize(GLFWHandler.GetWindow()))
        return false;

    Logger::Log("D3d11 initialization successful.");
    return true;
}